# Copy this file to .env and fill in real values. Never commit the real .env file.

# Connection string from Neon.tech (Postgres). Looks like:
# postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# Any long random string, used to sign login tokens. Example: run
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# and paste the result here.
JWT_SECRET=

# Up to 3 YouTube Data API v3 keys (from Google Cloud Console). At least
# YT_API_KEY_1 is required; 2 and 3 are optional extra quota.
YT_API_KEY_1=
YT_API_KEY_2=
YT_API_KEY_3=

# Port the server listens on locally. Render sets its own PORT automatically.
PORT=3000
